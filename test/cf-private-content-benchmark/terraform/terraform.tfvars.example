enable_azure              = false
enable_experimental_stack = true
aws_region                = "ap-northeast-2"
experiment_name_prefix    = "cf-private-benchmark"
benchmark_miss_iterations = 20
benchmark_hit_iterations  = 30
bootstrap_server_host     = "127.0.0.1"
bootstrap_server_port     = 3100

resource_group_name = "rg-cf-private-content-benchmark"
location            = "koreasouth"
vm_name             = "cf-benchmark-vm"
vm_size             = "Standard_B1s"
admin_username      = "azureuser"
admin_ssh_key_path  = "~/.ssh/id_rsa.pub"
allowed_ssh_cidrs   = ["203.0.113.10/32"]

tags = {
  project     = "cf-private-content-benchmark"
  environment = "test"
}
