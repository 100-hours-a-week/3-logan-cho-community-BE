          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e4" value="4. post 저장&#xa;imageCompletion=false" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#ff8a00;strokeWidth=3;endArrow=block;fontSize=14;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="spring" target="db">
          <mxGeometry relative="1" as="geometry" />
