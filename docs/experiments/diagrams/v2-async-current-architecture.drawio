        </mxCell>
        <mxCell id="e2" value="2. image 업로드&#xa;(temp 경로)" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#2dbd6e;strokeWidth=3;endArrow=block;fontSize=14;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="client" target="s3">
          <mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="170" y="360" /><mxPoint x="620" y="360" /></Array></mxGeometry>
