          </mxGeometry>
        </mxCell>
        <mxCell id="e6" value="6. 202/200 응답&#xa;postId + PENDING" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#29c7c7;strokeWidth=3;dashed=1;endArrow=block;fontSize=14;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="spring" target="client">
          <mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="700" y="700" /><mxPoint x="260" y="700" /></Array></mxGeometry>
