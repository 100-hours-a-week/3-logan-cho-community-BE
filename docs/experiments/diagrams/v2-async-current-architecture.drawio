        <mxCell id="e5" value="5. 작업 메시지 publish" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#29c7c7;strokeWidth=3;endArrow=block;fontSize=14;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="spring" target="sqs">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="1040" y="610" />
