          <mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="1560" y="250" /><mxPoint x="1040" y="250" /><mxPoint x="1040" y="200" /><mxPoint x="920" y="200" /></Array></mxGeometry>
        </mxCell>
        <mxCell id="e9" value="9. 본문 20% 압축&#xa;썸네일 80% 압축" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#3399ff;strokeWidth=3;endArrow=block;fontSize=14;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="lambda" target="s3">
          <mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="1660" y="240" /><mxPoint x="1660" y="80" /><mxPoint x="1050" y="80" /><mxPoint x="920" y="80" /></Array></mxGeometry>
        </mxCell>
        <mxCell id="e10" value="10. 작업 완료 callback" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#3399ff;strokeWidth=3;endArrow=block;fontSize=14;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="lambda" target="spring">
          <mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="1560" y="320" /><mxPoint x="1090" y="320" /><mxPoint x="1090" y="560" /><mxPoint x="980" y="560" /></Array></mxGeometry>
        </mxCell>
        <mxCell id="e11" value="11. 상태 저장&#xa;imageCompletion=true" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#ff8a00;strokeWidth=3;endArrow=block;fontSize=14;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="spring" target="db">
          <mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="1040" y="670" /><mxPoint x="1140" y="670" /><mxPoint x="1140" y="650" /><mxPoint x="1560" y="650" /></Array></mxGeometry>
        </mxCell>
        <mxCell id="e12" value="12. 상태조회 요청&#xa;(lazy retry / polling)" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#7a4dff;strokeWidth=3;endArrow=block;fontSize=14;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="client" target="spring">
          <mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="260" y="760" /><mxPoint x="760" y="760" /></Array></mxGeometry>
