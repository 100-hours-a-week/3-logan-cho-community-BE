        <mxCell id="e13" value="13. 상태조회 202/완료 응답" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#7a4dff;strokeWidth=3;dashed=1;endArrow=block;fontSize=14;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="spring" target="client">
