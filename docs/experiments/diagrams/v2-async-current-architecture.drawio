<mxfile host="app.diagrams.net" agent="Codex">
  <diagram id="v2-async-current-architecture" name="V2 Async Current Architecture">
    <mxGraphModel dx="1600" dy="1000" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="2400" pageHeight="1400" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="title" value="V2 Async Image Pipeline" style="text;html=1;strokeColor=none;fillColor=none;align=left;fontSize=28;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="24" width="460" height="36" as="geometry" />
        </mxCell>
        <mxCell id="subtitle" value="사용자 요청은 빠르게 응답하고, 실제 이미지 처리와 완료 반영은 SQS + Lambda 뒤에서 끝낸다." style="text;html=1;strokeColor=none;fillColor=none;align=left;fontSize=14;fontColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="40" y="62" width="1040" height="24" as="geometry" />
        </mxCell>

        <mxCell id="client" value="Client" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#2f4858;strokeWidth=2;fontStyle=1;fontSize=18;" vertex="1" parent="1">
          <mxGeometry x="80" y="560" width="180" height="90" as="geometry" />
        </mxCell>
        <mxCell id="s3" value="S3&#xa;&#xa;temp/{timestamp}/xxx.png&#xa;public/post/{postId}/xxx.png&#xa;public/post/{postId}/thumbnail/xxx.png" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f7fff0;strokeColor=#7aa61c;strokeWidth=2;fontSize=16;" vertex="1" parent="1">
          <mxGeometry x="620" y="110" width="300" height="140" as="geometry" />
        </mxCell>
        <mxCell id="appZone" value="App EC2" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#ffb366;strokeWidth=2;dashed=1;fontStyle=1;fontSize=16;verticalAlign=top;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="700" y="470" width="340" height="260" as="geometry" />
        </mxCell>
        <mxCell id="spring" value="Spring Server&#xa;&#xa;post PENDING 저장&#xa;+ SQS publish" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff4e6;strokeColor=#f08c00;strokeWidth=2;fontStyle=1;fontSize=18;" vertex="1" parent="1">
          <mxGeometry x="760" y="560" width="220" height="110" as="geometry" />
        </mxCell>
        <mxCell id="sqs" value="SQS" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff0f6;strokeColor=#d63384;strokeWidth=2;fontStyle=1;fontSize=18;" vertex="1" parent="1">
          <mxGeometry x="1240" y="400" width="180" height="100" as="geometry" />
        </mxCell>
        <mxCell id="lambda" value="Lambda" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff4e6;strokeColor=#f08c00;strokeWidth=2;fontStyle=1;fontSize=18;" vertex="1" parent="1">
          <mxGeometry x="1560" y="110" width="180" height="100" as="geometry" />
        </mxCell>
        <mxCell id="db" value="MongoDB&#xa;&#xa;imageCompletion=false/true" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#eefaf6;strokeColor=#20c997;strokeWidth=2;fontStyle=1;fontSize=18;" vertex="1" parent="1">
          <mxGeometry x="1560" y="600" width="250" height="110" as="geometry" />
        </mxCell>
        <mxCell id="note" value="핵심: 사용자는 먼저 `PENDING` 응답을 받고, 이후 polling으로 완료 여부를 확인한다." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff9db;strokeColor=#fcc419;strokeWidth=2;fontSize=15;" vertex="1" parent="1">
          <mxGeometry x="1080" y="300" width="430" height="90" as="geometry" />
        </mxCell>

        <mxCell id="e1" value="1. presigned-url 발급 요청" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#2dbd6e;strokeWidth=3;endArrow=block;fontSize=14;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="client" target="spring">
