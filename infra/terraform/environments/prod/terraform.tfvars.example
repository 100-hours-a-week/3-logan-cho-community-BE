project_name = "kaboocam-post"
environment  = "prod"
aws_region   = "ap-northeast-2"

availability_zones = ["ap-northeast-2a", "ap-northeast-2c"]
vpc_cidr           = "10.20.0.0/16"
public_subnet_cidrs = [
  "10.20.0.0/24",
  "10.20.1.0/24"
]
private_subnet_cidrs = [
  "10.20.10.0/24",
  "10.20.11.0/24"
]

ami_id              = "ami-xxxxxxxxxxxxxxxxx" # Golden AMI artifact_id from infra/packer build
instance_type       = "t3.small"
asg_min_size        = 3
asg_max_size        = 6
asg_desired_capacity = 3
asg_cpu_target      = 60
# app_user_data     = file("user-data/golden-ami-app.sh")

rds_master_username = "appadmin"
rds_master_password = "CHANGE_ME"
rds_instance_class  = "db.t4g.small"
rds_backup_retention_days = 7
rds_skip_final_snapshot = false
rds_final_snapshot_identifier = "kaboocam-post-prod-final"

redis_node_type = "cache.t4g.micro"

tags = {
  Owner = "platform-team"
}
