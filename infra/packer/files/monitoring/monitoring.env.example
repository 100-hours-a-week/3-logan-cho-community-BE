# Monitoring Stack Environment Variables
# Copy this file to /etc/default/monitoring and customize

# Application name for Promtail job label
# This will be used as the 'job' label in Loki
# Examples: backend, frontend, ai-server
APP_NAME=backend

# Loki URL (if using external Loki server)
# LOKI_URL=http://loki.example.com:3100/loki/api/v1/push